-- DISABLE RAYFIELD ERROR NOTIFICATIONS
local originalNotify = Rayfield.Notify

-- Function to filter out error notifications
Rayfield.Notify = function(data)
    if data and data.Title and (string.find(data.Title, "Error") or string.find(data.Content, "error")) then
        return
    end
    originalNotify(data)
end

-- Disable internal error handler
pcall(function()
    if Rayfield._errorHandler then
        Rayfield._errorHandler = function() end
    end
    getgenv().RayfieldDebug = false
end)

